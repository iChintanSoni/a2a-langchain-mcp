{
  "name": "file-server",
  "version": "1.0.0",
  "description": "File server for the A2A ecosystem",
  "scripts": {
    "dev": "node --experimental-transform-types --watch-path=./src --env-file=.env src/index.ts",
    "prod": "node --experimental-transform-types src/index.ts",
    "test": "node --experimental-transform-types --test tests/*.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "common": "file:../../packages/common",
