    "express": "^5",
    "multer": "^2.1.1",
    "uuid": "^14.0.0",
    "zod": "^4"
  },
  "imports": {
    "#src/*": "./src/*"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5",
    "@types/multer": "^2.1.0",
    "@types/uuid": "^10.0.0"
  }
}
